{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "isolatedModules": true,
    "types": ["vite/client"]
  },
  "include": ["app/TourIntelligence.tsx", "src/**/*.tsx", "vite.pages.config.ts"],
  "exclude": ["node_modules", "pages-dist"]
}
